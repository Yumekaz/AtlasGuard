PORT=3001
JWT_SECRET=fallback_secret_key_change_me_in_production

# Redis 5+ required for BullMQ notifications (default dev: Docker on 6379)
REDIS_URL=redis://127.0.0.1:6379

# Start local infra: npm run infra:up (from repo root)
# Optional dev-only fallback if Docker is unavailable (not for production):
# REDIS_FALLBACK_MEMORY=true